// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth required models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // Hashed password for credentials authentication
  isAppAdmin    Boolean   @default(false) // App-level administrator
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  households     HouseholdMember[]
  preferences    UserPreferences?
  unitUsage      UserUnitUsage[]
  unitPreference UserIngredientUnitPreference[]
  communityLikes CommunityRecipeLike[]
  communitySaves CommunityRecipeSave[]
  passwordResetTokens PasswordResetToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuthRateLimitEvent {
  id          String   @id @default(cuid())
  scope       String
  subjectHash String
  ipHash      String
  windowStart DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scope, subjectHash, ipHash, windowStart])
  @@index([scope])
  @@index([windowStart])
}

// Household models
model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members             HouseholdMember[]
  locations           KitchenLocation[]
  inventoryItems      InventoryItem[]
  recipes             Recipe[]
  shoppingList        ShoppingList?
  installedExtensions InstalledExtension[]
  integrations        Integration[]
  aiProviderSettings  AiProviderSettings[]
}

enum HouseholdRole {
  owner
  admin
  member
}

enum UnitType {
  count
  volume
  mass
  length
  time
  temperature
  package
  qualitative
}

enum UnitSystem {
  us
  metric
  neutral
}

model HouseholdMember {
  id          String        @id @default(cuid())
  userId      String
  householdId String
  role        HouseholdRole @default(member)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
  @@index([userId])
  @@index([householdId])
}

// Core data models
model FoodItem {
  id            String   @id @default(cuid())
  name          String
  canonicalName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  barcodes          Barcode[]
  inventoryItems    InventoryItem[]
  recipeIngredients RecipeIngredient[]
  shoppingListItems ShoppingListItem[]
}

model Barcode {
  id              String   @id @default(cuid())
  foodItemId      String
  code            String // UPC/EAN
  type            String // 'UPC' | 'EAN'
  source          String   @default("LOCAL_MANUAL") // 'LOCAL_MANUAL' | 'OPEN_FOOD_FACTS'
  manualLocked    Boolean  @default(false)
  brand           String?
  categoriesTags  String[] @default([])
  ingredientsText String?  @db.Text
  allergensTags   String[] @default([])
  nutriscoreGrade String?
  novaGroup       Int?
  ecoscoreGrade   String?
  imageFrontUrl   String?
  nutritionPer100g Json?
  attributionUrl  String?
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())

  foodItem FoodItem @relation(fields: [foodItemId], references: [id], onDelete: Cascade)

  @@unique([code])
  @@index([foodItemId])
}

model KitchenLocation {
  id          String   @id @default(cuid())
  householdId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]

  @@index([householdId])
}

model InventoryItem {
  id          String    @id @default(cuid())
  householdId String
  foodItemId  String
  locationId  String
  quantity    Float
  unit        String
  expiresOn   DateTime?
  category    String?
  notes       String?   @db.Text
  photoUrl    String?
  barcode     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  household   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  foodItem    FoodItem        @relation(fields: [foodItemId], references: [id])
  location    KitchenLocation @relation(fields: [locationId], references: [id])
  mediaAssets MediaAsset[]

  @@index([householdId])
  @@index([locationId])
  @@index([foodItemId])
  @@index([expiresOn])
}

model MediaAsset {
  id              String   @id @default(cuid())
  url             String
  recipeId        String?
  inventoryItemId String?
  uploadedAt      DateTime @default(now())

  recipe        Recipe?        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([inventoryItemId])
}

model Recipe {
  id               String    @id @default(cuid())
  householdId      String
  title            String
  description      String?   @db.Text
  photoUrl         String?
  tags             String[]
  visibility       String    @default("private") // 'private' | 'household' | 'public' | 'unlisted'
  servings         Int?
  totalTimeMinutes Int?
  caloriesKcal     Float?
  proteinGrams     Float?
  carbsGrams       Float?
  fatGrams         Float?
  sourceUrl        String?
  notes            String?   @db.Text
  favorited        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastCookedAt     DateTime?

  household         Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ingredients       RecipeIngredient[]
  steps             RecipeStep[]
  mediaAssets       MediaAsset[]
  shoppingListItems ShoppingListItem[]
  communityLikes    CommunityRecipeLike[]
  communitySaves    CommunityRecipeSave[]

  @@index([householdId])
  @@index([visibility])
}

model RecipeIngredient {
  id         String   @id @default(cuid())
  recipeId   String
  foodItemId String?
  name       String
  quantity   Float?
  unit       String?
  note       String?
  order      Int
  createdAt  DateTime @default(now())

  recipe   Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodItem FoodItem? @relation(fields: [foodItemId], references: [id])

  @@index([recipeId])
  @@index([foodItemId])
}

model RecipeStep {
  id        String   @id @default(cuid())
  recipeId  String
  text      String   @db.Text
  order     Int
  createdAt DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model ShoppingList {
  id          String   @id @default(cuid())
  householdId String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items     ShoppingListItem[]
}

model ShoppingListItem {
  id             String   @id @default(cuid())
  shoppingListId String
  foodItemId     String?
  name           String
  quantity       Float?
  unit           String?
  category       String?
  checked        Boolean  @default(false)
  note           String?  @db.Text
  source         String? // 'manual' | 'from-recipe' | 'low-stock'
  recipeId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  foodItem     FoodItem?    @relation(fields: [foodItemId], references: [id])
  recipe       Recipe?      @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([shoppingListId])
  @@index([foodItemId])
}

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique
  measurementSystem String   @default("metric") // 'metric' | 'imperial'
  defaultWeightUnit String   @default("g") // 'g' | 'kg' | 'oz' | 'lb'
  defaultVolumeUnit String   @default("ml") // 'ml' | 'l' | 'cup' | 'tbsp' | 'tsp'
  timezone          String?
  dateFormat        String?  @default("YYYY-MM-DD")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Unit {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String
  abbr         String?
  unitType     UnitType
  system       UnitSystem @default(neutral)
  baseUnitId   String?
  toBaseFactor Float?
  isCommon     Boolean    @default(false)
  isEnabled    Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  baseUnit                 Unit?                           @relation("UnitBase", fields: [baseUnitId], references: [id], onDelete: SetNull)
  derivedUnits             Unit[]                          @relation("UnitBase")
  aliases                  UnitAlias[]
  defaultIngredientProfiles IngredientUnitProfile[]        @relation("IngredientDefaultUnit")
  profileRecommendations   IngredientUnitProfileRecommendation[]
  userUsage                UserUnitUsage[]
  userIngredientPreferences UserIngredientUnitPreference[]

  @@index([unitType, isCommon, isEnabled])
  @@index([name])
}

model UnitAlias {
  id        String   @id @default(cuid())
  unitId    String
  alias     String
  priority  Int      @default(0)
  createdAt DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, alias])
  @@index([alias])
}

model IngredientUnitProfile {
  id            String   @id @default(cuid())
  ingredientKey String   @unique
  defaultUnitId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  defaultUnit      Unit?                                  @relation("IngredientDefaultUnit", fields: [defaultUnitId], references: [id], onDelete: SetNull)
  recommendations  IngredientUnitProfileRecommendation[]
}

model IngredientUnitProfileRecommendation {
  id        String @id @default(cuid())
  profileId String
  unitId    String
  rank      Int    @default(0)

  profile IngredientUnitProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  unit    Unit                  @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([profileId, unitId])
  @@index([profileId, rank])
}

model UserUnitUsage {
  id         String   @id @default(cuid())
  userId     String
  unitId     String
  count      Int      @default(0)
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([userId, unitId])
  @@index([userId, lastUsedAt])
}

model UserIngredientUnitPreference {
  id            String   @id @default(cuid())
  userId        String
  ingredientKey String
  unitId        String
  count         Int      @default(0)
  lastUsedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([userId, ingredientKey, unitId])
  @@index([userId, ingredientKey, lastUsedAt])
}

// Community & Extensions models
model CommunityRecipeLike {
  id        String   @id @default(cuid())
  recipeId  String
  userId    String
  createdAt DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId, userId])
  @@index([recipeId])
  @@index([userId])
}

model CommunityRecipeSave {
  id        String   @id @default(cuid())
  recipeId  String
  userId    String
  createdAt DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId, userId])
  @@index([recipeId])
  @@index([userId])
}

model ExtensionListing {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  category    String
  tags        String[]
  authorName  String
  authorUrl   String?
  pricing     String // 'free' | 'paid' | 'trial'
  rating      Float?
  installs    Int      @default(0)
  permissions String[]
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  installedExtensions InstalledExtension[]

  @@index([category])
  @@index([enabled])
}

model InstalledExtension {
  id                 String   @id @default(cuid())
  extensionId        String
  householdId        String
  enabled            Boolean  @default(true)
  needsConfiguration Boolean  @default(false)
  configuration      String?  @db.Text // JSON config
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  extension ExtensionListing @relation(fields: [extensionId], references: [id], onDelete: Cascade)
  household Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([extensionId, householdId])
  @@index([householdId])
  @@index([extensionId])
}

model Integration {
  id           String    @id @default(cuid())
  householdId  String
  provider     String // e.g., 'instacart', 'google-drive'
  name         String
  description  String    @db.Text
  status       String // 'connected' | 'disconnected' | 'error'
  scopes       String[]
  accessToken  String?   @db.Text // Encrypted
  refreshToken String?   @db.Text // Encrypted
  expiresAt    DateTime?
  lastSyncAt   DateTime?
  config       String?   @db.Text // JSON config
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, provider])
  @@index([householdId])
  @@index([provider])
}

model AiProviderSettings {
  id           String    @id @default(cuid())
  householdId  String
  providerId   String // e.g., 'openai', 'anthropic', 'google'
  providerName String
  apiKey       String?   @db.Text // Encrypted
  model        String? // e.g., 'gpt-4', 'claude-3.5-sonnet'
  status       String    @default("needs-key") // 'ready' | 'needs-key' | 'error'
  isActive     Boolean   @default(false)
  lastTestedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, providerId])
  @@index([householdId])
  @@index([providerId])
}
