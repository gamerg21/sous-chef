# Convex
NEXT_PUBLIC_CONVEX_URL="https://your-deployment.convex.cloud"
CONVEX_DEPLOY_KEY="prod:your-deploy-key"

# Auth and app URLs
APP_BASE_URL="http://localhost:3000"

# Optional password reset email delivery
RESEND_API_KEY=""
SMTP_FROM="Sous Chef <no-reply@souschef.local>"

# Open Food Facts barcode enrichment (optional)
OPEN_FOOD_FACTS_ENABLED="true"
OPEN_FOOD_FACTS_API_BASE_URL="https://world.openfoodfacts.org"
OPEN_FOOD_FACTS_USER_AGENT="SousChef/0.1.1 (reuse@example.com)"
OPEN_FOOD_FACTS_TIMEOUT_MS="2500"
OPEN_FOOD_FACTS_CACHE_TTL_DAYS="30"
OPEN_FOOD_FACTS_BACKFILL_BATCH_SIZE="50"
